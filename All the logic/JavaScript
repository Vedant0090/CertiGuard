// ⬇️ DOWNLOAD REPORT — creates a .txt file and triggers download
function downloadReport() {
  const blob = new Blob([`CERTIGUARD REPORT\n...`], { type: 'text/plain' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'certiguard_report.txt';
  a.click();
}

